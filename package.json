{
  "name": "style-parser",
  "version": "1.0.0",
  "description": "Transpiler de fichiers .style (YAML) vers CSS, SCSS et CSS-in-JS",
  "keywords": [
    "css",
    "sass",
    "scss",
    "yaml",
    "transpiler",
    "css-in-js",
    "design-tokens"
  ],
  "author": "",
  "license": "MIT",
  "main": "lib/index.js",
  "bin": {
    "style-parser": "./bin/cli.js"
  },
  "exports": {
    ".": "./lib/index.js",
    "./generators/css": "./lib/generators/css.js",
    "./generators/sass": "./lib/generators/sass.js",
    "./generators/css-in-js": "./lib/generators/css-in-js.js"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md"
  ],
  "scripts": {
    "test": "node test/index.test.js",
    "build": "echo 'No build step needed (CJS)'",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "chalk": "^5.6.2"
  }
}
